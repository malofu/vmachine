#!/usr/bin/env php
<?php

declare(strict_types=1);

use VendingMachine\Application\BuyProduct\BuyProductHandler;
use VendingMachine\Application\InsertCoin\InsertCoinHandler;
use VendingMachine\Application\ReturnCoins\ReturnCoinsHandler;
use VendingMachine\Application\ServiceMachine\ServiceMachineHandler;
use VendingMachine\Application\ViewState\ViewStateHandler;
use VendingMachine\Domain\Coin;
use VendingMachine\Domain\CoinBank;
use VendingMachine\Domain\Inventory;
use VendingMachine\Domain\Product;
use VendingMachine\Domain\VendingMachine;
use VendingMachine\Infrastructure\Cli\VendingMachineConsole;
use VendingMachine\Infrastructure\Persistence\InMemoryVendingMachineRepository;

require __DIR__ . '/../vendor/autoload.php';

// Minimal .env loader (no dependency): each KEY=VALUE line becomes an env var,
// unless already set in the real environment. Keeps secrets like the service
// code out of the code and out of version control.
$envFile = __DIR__ . '/../.env';
if (is_file($envFile)) {
    foreach (file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (str_starts_with(ltrim($line), '#')) {
            continue;
        }

        [$name, $value] = array_pad(explode('=', $line, 2), 2, '');
        $name = trim($name);

        if ($name !== '' && getenv($name) === false) {
            putenv($name . '=' . trim($value));
        }
    }
}

// Seed the machine with stock and change so it can vend right away. Setting
// this at runtime is the Service technician's job (a later story); until then
// the bootstrap provisions sensible defaults here in the infrastructure layer.
$inventory = Inventory::empty()
    ->withStock(Product::Water, 5)
    ->withStock(Product::Juice, 5)
    ->withStock(Product::Soda, 5);

$coinBank = CoinBank::empty()
    ->withCoins(Coin::OneEuro, 10)
    ->withCoins(Coin::TwentyFiveCents, 20)
    ->withCoins(Coin::TenCents, 20)
    ->withCoins(Coin::FiveCents, 20);

$repository = new InMemoryVendingMachineRepository();
$repository->save(VendingMachine::stocked($inventory, $coinBank));

// The passcode that unlocks service mode — infrastructure config from .env,
// standing in for the technician's physical key (not real authentication).
$serviceCode = getenv('SERVICE_CODE');
if ($serviceCode === false || $serviceCode === '') {
    fwrite(STDERR, 'SERVICE_CODE is not set. Copy .env.example to .env and set it.' . PHP_EOL);
    exit(1);
}

$console = new VendingMachineConsole(
    new InsertCoinHandler($repository),
    new ReturnCoinsHandler($repository),
    new BuyProductHandler($repository),
    new ViewStateHandler($repository),
    new ServiceMachineHandler($repository),
    $serviceCode,
);

$console->run();
