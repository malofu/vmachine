#!/usr/bin/env php
<?php

declare(strict_types=1);

use VendingMachine\Application\BuyProduct\BuyProductHandler;
use VendingMachine\Application\InsertCoin\InsertCoinHandler;
use VendingMachine\Application\RemoveProduct\RemoveProductHandler;
use VendingMachine\Application\ReturnCoins\ReturnCoinsHandler;
use VendingMachine\Application\ServiceMachine\ServiceReportHandler;
use VendingMachine\Application\SetChange\SetChangeHandler;
use VendingMachine\Application\SetProductPrice\SetProductPriceHandler;
use VendingMachine\Application\SetProductStock\SetProductStockHandler;
use VendingMachine\Application\ViewState\ViewStateHandler;
use VendingMachine\Domain\Coin;
use VendingMachine\Domain\CoinBank;
use VendingMachine\Domain\Inventory;
use VendingMachine\Domain\Product;
use VendingMachine\Domain\ProductCatalogue;
use VendingMachine\Domain\VendingMachine;
use VendingMachine\Infrastructure\Cli\VendingMachineConsole;
use VendingMachine\Infrastructure\Persistence\InMemoryVendingMachineRepository;
use VendingMachine\Infrastructure\Persistence\SqliteVendingMachineRepository;

require __DIR__ . '/../vendor/autoload.php';

// Minimal .env loader (no dependency): each KEY=VALUE line becomes an env var,
// unless already set in the real environment. Keeps secrets like the service
// code out of the code and out of version control.
$envFile = __DIR__ . '/../.env';
if (is_file($envFile)) {
    foreach (file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (str_starts_with(ltrim($line), '#')) {
            continue;
        }

        [$name, $value] = array_pad(explode('=', $line, 2), 2, '');
        $name = trim($name);

        if ($name !== '' && getenv($name) === false) {
            putenv($name . '=' . trim($value));
        }
    }
}

// Default provisioning for a machine that has never been stocked. Setting this
// at runtime is the Service technician's job; the bootstrap just seeds sensible
// defaults for a fresh store. For SQLite these defaults live in data/seed.sql;
// the PHP factory below seeds the in-memory store, which cannot run SQL.
$defaultMachine = static function (): VendingMachine {
    $catalogue = ProductCatalogue::empty()
        ->withProduct(Product::new('WATER', 65))
        ->withProduct(Product::new('JUICE', 100))
        ->withProduct(Product::new('SODA', 150));

    $inventory = Inventory::empty()
        ->withStock('WATER', 5)
        ->withStock('JUICE', 5)
        ->withStock('SODA', 5);

    $coinBank = CoinBank::empty()
        ->withCoins(Coin::OneEuro, 10)
        ->withCoins(Coin::TwentyFiveCents, 20)
        ->withCoins(Coin::TenCents, 20)
        ->withCoins(Coin::FiveCents, 20);

    return VendingMachine::stocked($catalogue, $inventory, $coinBank);
};

// Pick the persistence adapter. Default: in-memory, so the state lives only for
// the process and the default run stays side-effect-free. Opt into durable
// storage with PERSISTENCE=sqlite; DB_PATH sets the database file (relative
// paths resolve from the project root, default data/machine.sqlite).
$persistence = getenv('PERSISTENCE') ?: 'memory';

if ($persistence === 'sqlite') {
    $dataDir = dirname(__DIR__) . '/data';

    $dbPath = getenv('DB_PATH') ?: 'data/machine.sqlite';
    if (preg_match('#^(/|[A-Za-z]:)#', $dbPath) !== 1) {
        $dbPath = dirname(__DIR__) . '/' . $dbPath;
    }

    $dbDir = dirname($dbPath);
    if (!is_dir($dbDir)) {
        mkdir($dbDir, 0777, true);
    }

    $pdo = new PDO('sqlite:' . $dbPath);
    $repository = new SqliteVendingMachineRepository($pdo, $dataDir . '/schema.sql');

    // Seed only a never-provisioned store, from the shipped SQL; an existing
    // database is loaded verbatim, so a restart resumes the real state. "Never
    // provisioned" means every table the seed writes is empty: guarding on the
    // catalogue alone would let the seed collide with pre-existing coin_bank or
    // inventory rows and crash on a PRIMARY KEY conflict.
    $machine = $repository->get();
    $unprovisioned = $machine->catalogue()->all() === []
        && $machine->inventory()->counts() === []
        && $machine->coinBank()->counts() === [];

    if ($unprovisioned) {
        $pdo->exec((string) file_get_contents($dataDir . '/seed.sql'));
    }
} else {
    $repository = new InMemoryVendingMachineRepository();
    $repository->save($defaultMachine());
}

// The passcode that unlocks service mode — infrastructure config from .env,
// standing in for the technician's physical key (not real authentication).
$serviceCode = getenv('SERVICE_CODE');
if ($serviceCode === false || $serviceCode === '') {
    fwrite(STDERR, 'SERVICE_CODE is not set. Copy .env.example to .env and set it.' . PHP_EOL);
    exit(1);
}

$console = new VendingMachineConsole(
    new InsertCoinHandler($repository),
    new ReturnCoinsHandler($repository),
    new BuyProductHandler($repository),
    new ViewStateHandler($repository),
    new SetProductPriceHandler($repository),
    new SetProductStockHandler($repository),
    new RemoveProductHandler($repository),
    new SetChangeHandler($repository),
    new ServiceReportHandler($repository),
    $serviceCode,
);

$console->run();
