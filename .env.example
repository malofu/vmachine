# Passcode that unlocks the technician service mode in the CLI.
# Copy this file to .env and change the value. Simulates the technician's
# physical key — it is not real authentication.
SERVICE_CODE=1234

# Where the machine keeps its state.
#   memory  (default) — state lives only for the process; nothing is written.
#   sqlite            — state persists in a SQLite database and survives restarts.
PERSISTENCE=memory

# SQLite database file, used only when PERSISTENCE=sqlite. Relative paths
# resolve from the project root; the file is created on first run.
DB_PATH=data/machine.sqlite
